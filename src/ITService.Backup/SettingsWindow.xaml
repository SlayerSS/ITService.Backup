<Window x:Class="ITService.Backup.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки — ITBackup"
        Icon="/Assets/app.ico"
        Height="600" Width="500" MinHeight="460" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="SQL Server (1С)">
                <Grid Margin="10,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <CheckBox x:Name="SqlThisPcCheck" Content="SQL на этом компьютере"
                                  Margin="0,0,0,6"/>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SqlServerLabel" Text="Сервер" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="12" Foreground="{StaticResource MutedBrush}"/>
                            <TextBox x:Name="SqlInstanceBox" Grid.Column="1" Height="28" VerticalContentAlignment="Center"
                                     ToolTip="IP, имя хоста или сервер\экземпляр — как в SSMS (например 192.168.1.10 или SQL01\INST)"/>
                            <TextBlock x:Name="SqlLocalInstanceText" Grid.Column="1" VerticalAlignment="Center"
                                       FontSize="12" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>
                            <Button Grid.Column="2" Content="Проверить" Style="{StaticResource SecondaryButton}"
                                    Click="TestConnection_Click" Margin="8,0,0,0" Padding="10,4"
                                    MinWidth="72" FontSize="12" VerticalAlignment="Center"/>
                        </Grid>

                        <WrapPanel Margin="0,0,0,2">
                            <CheckBox x:Name="WindowsAuthCheck" Content="Вход Windows" VerticalAlignment="Center"
                                      Margin="0,0,12,4"
                                      ToolTip="Подключение под учётной записью Windows (текущий пользователь)"/>
                            <CheckBox x:Name="SqlExcludeLogsCheck" Content="Без журнала (.ldf)" IsChecked="True"
                                      Margin="0,0,12,4" VerticalAlignment="Center"
                                      ToolTip="Не включать в бэкап файлы журнала транзакций SQL (.ldf) — меньше размер .bak"/>
                            <CheckBox x:Name="SqlCompressionCheck" Content="Сжатие" IsChecked="True"
                                      Margin="0,0,12,4" VerticalAlignment="Center"/>
                            <Button Content="Обновить базы" Style="{StaticResource SecondaryButton}"
                                    Click="RefreshDatabases_Click" Padding="8,4" FontSize="12"
                                    Margin="0,0,0,4" VerticalAlignment="Center"/>
                        </WrapPanel>

                        <StackPanel x:Name="SqlAuthPanel" Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBox x:Name="SqlUserBox" Width="140" Height="28" VerticalContentAlignment="Center"
                                     Margin="0,0,8,0" ToolTip="Логин SQL"/>
                            <PasswordBox x:Name="SqlPasswordBox" Width="140" Height="28"
                                        VerticalContentAlignment="Center" ToolTip="Пароль SQL"/>
                        </StackPanel>

                        <TextBlock x:Name="SqlConnectionStatus" FontSize="10" Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="10,8">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="Базы на сервере" FontWeight="SemiBold"
                                       FontSize="13" Margin="0,0,0,4"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Список баз на сервере. Что копировать — галочками в окне программы."
                                       FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"
                                       TextWrapping="Wrap"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="DatabasesList"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Папки">
                <DockPanel Margin="10,8" LastChildFill="True">
                    <CheckBox x:Name="AutoAddOneCCheck" DockPanel.Dock="Top"
                              Content="Находить файловые базы 1С при запуске"
                              IsChecked="True" Margin="0,0,0,8"
                              ToolTip="Пути из списка 1С пользователя (ibases.v8i) добавляются в список ниже"/>
                    <WrapPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                        <Button Content="Добавить папку" Style="{StaticResource SecondaryButton}"
                                Click="AddFolder_Click" Margin="0,0,8,8"/>
                        <Button Content="Указать файл .v8i…" Style="{StaticResource SecondaryButton}"
                                Click="ImportFromV8iFile_Click" Margin="0,0,8,8"
                                ToolTip="Ручной импорт списка баз. Пути 1С подтягиваются при запуске программы."/>
                        <Button Content="Удалить выбранную" Style="{StaticResource SecondaryButton}"
                                Click="RemoveFolder_Click" Margin="0,0,0,8"/>
                    </WrapPanel>
                    <Border Style="{StaticResource CardBorder}" Padding="8,6">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="Папки для копирования" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"
                                       Text="Список папок для копирования. Метка «1С» — если в каталоге есть файл базы (.1CD)."/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="FoldersList"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </TabItem>

            <TabItem Header="Носитель и прочее">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="8">
                    <CheckBox x:Name="RemovableOnlyCheck"
                              Content="Копировать только на съёмный USB"
                              Margin="0,0,0,8" IsChecked="True"
                              Click="BackupTarget_Changed"/>

                    <StackPanel x:Name="TargetModePanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Куда сохранять резервную копию" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="SaveToDiskRadio" Content="На любой диск" GroupName="SaveTarget"
                                         Margin="0,0,20,0" IsChecked="True" Click="SaveTargetMode_Changed"/>
                            <RadioButton x:Name="SaveToFolderRadio" Content="В папку на этом ПК"
                                         GroupName="SaveTarget" Click="SaveTargetMode_Changed"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="DiskTargetPanel" Margin="0,0,0,8">
                        <CheckBox x:Name="AutoDetectUsbCheck"
                                  Content="Автоопределение съёмного диска"
                                  Margin="0,0,0,6" IsChecked="True"
                                  Click="AutoDetectUsb_Changed"/>
                        <CheckBox x:Name="PickDriveManuallyCheck"
                                  Content="Выбрать диск вручную"
                                  Margin="0,0,0,4"
                                  Click="PickDriveManually_Changed"/>
                        <ComboBox x:Name="DriveLetterCombo" Height="28" MaxWidth="360"
                                  HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                  DisplayMemberPath="Display"
                                  SelectionChanged="DriveLetterCombo_SelectionChanged"/>
                        <Border x:Name="NonRemovableDriveWarningPanel" Visibility="Collapsed"
                                Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="1"
                                CornerRadius="4" Padding="8,6" Margin="0,0,0,6">
                            <TextBlock x:Name="NonRemovableDriveWarningText" TextWrapping="Wrap"
                                       FontSize="11" Foreground="#E65100"/>
                        </Border>
                    </StackPanel>

                    <StackPanel x:Name="FolderTargetPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Папка для резервных копий на этом ПК" Margin="0,0,0,4"
                                   FontSize="12"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="LocalFolderBox" Grid.Column="0" Height="28"
                                     VerticalContentAlignment="Center" Margin="0,0,8,0"
                                     TextChanged="LocalFolderBox_TextChanged"/>
                            <Button x:Name="BrowseLocalFolderButton" Grid.Column="1" Content="Обзор…"
                                    Style="{StaticResource SecondaryButton}" Padding="12,6"
                                    Click="BrowseLocalBackupFolder_Click"/>
                        </Grid>
                        <Border x:Name="LocalBackupWarningPanel" Visibility="Visible"
                                Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="1"
                                CornerRadius="4" Padding="8,6">
                            <TextBlock x:Name="LocalBackupWarningText" TextWrapping="Wrap" FontSize="11"
                                       Foreground="#E65100"/>
                        </Border>
                    </StackPanel>

                    <TextBlock x:Name="ArchiveSubfolderLabel" Text="Подпапка для архивов (внутри USB или выбранной папки)" Margin="0,0,0,4"/>
                    <TextBox x:Name="UsbRootBox" Margin="0,0,0,12"/>

                    <TextBlock Text="Формат имени папки архива" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ArchiveFormatCombo" Margin="0,0,0,12">
                        <ComboBoxItem Content="Дата (2026-05-21)" Tag="yyyy-MM-dd"/>
                        <ComboBoxItem Content="Дата и время (2026-05-21_14-30-00)" Tag="yyyy-MM-dd_HH-mm-ss"/>
                    </ComboBox>

                    <TextBlock Text="Текст подсказки в окне программы" Margin="0,0,0,4"/>
                    <TextBox x:Name="Warn1CBox" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Margin="0,0,0,12"/>

                    <CheckBox x:Name="RememberSelectionCheck" Content="Запоминать, что отмечено для копирования"
                              ToolTip="При следующем запуске восстановит ваш прошлый выбор галочек"/>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"
                       Text="IT Service · г. Ноябрьск · удалённая поддержка"/>
            <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10">
                <Run Text="☎ 8 961 552-52-52  ·  "/>
                <Hyperlink NavigateUri="https://it.nojabrsk.info/" RequestNavigate="Hyperlink_RequestNavigate">
                    it.nojabrsk.info
                </Hyperlink>
            </TextBlock>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="Save_Click" IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
